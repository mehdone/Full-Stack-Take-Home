# === App ===
NODE_ENV=development
PORT=3000

# === Postgres (docker-compose) ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=emissions
POSTGRES_USER=emissions
POSTGRES_PASSWORD=emissions

# Works for Drizzle/pg:
DATABASE_URL=postgresql://emissions:emissions@localhost:5432/emissions

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# === Kafka (KRaft single-broker) ===
KAFKA_PORT=9092
KAFKA_BROKERS=localhost:9092

# Topic names
INGEST_TOPIC=emissions.ingest.v1

# Redis edge-dedupe TTL for batch_id keys (seconds). Default: 24 h.
BATCH_DEDUPE_TTL_SECONDS=86400

# === Consumer ===
# Kafka consumer group ID. Override for blue/green deploys.
CONSUMER_GROUP_ID=emissions-ingest-consumer

# === Alerting receiver ===
# Port the alerting NestJS HTTP sink listens on.
ALERTING_PORT=4100

# === Outbox relay ===
# URL of the alerting receiver (used by both relays).
ALERTING_URL=http://localhost:4100
# Poll interval in milliseconds (how often the relay wakes up to scan the outbox table).
OUTBOX_RELAY_POLL_INTERVAL_MS=1000
# Number of outbox rows to lock and deliver per tick.
OUTBOX_RELAY_BATCH_SIZE=25
# Exponential backoff base (seconds). Retry N uses min(2^N * base, cap) + jitter.
OUTBOX_BACKOFF_BASE_SECONDS=2
# Exponential backoff ceiling (seconds).
OUTBOX_BACKOFF_CAP_SECONDS=300
# After this many delivery failures the row is frozen and a system_alert is written.
OUTBOX_MAX_ATTEMPTS=10

# === System-alerts relay ===
# Same semantics as the outbox relay, but scans the system_alerts table.
SYSTEM_ALERTS_POLL_INTERVAL_MS=1000
SYSTEM_ALERTS_BATCH_SIZE=25
SYSTEM_ALERTS_BACKOFF_BASE_SECONDS=2
SYSTEM_ALERTS_BACKOFF_CAP_SECONDS=300
SYSTEM_ALERTS_MAX_ATTEMPTS=10

# === pgAdmin (optional, only if running with --profile tools) ===
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# === Kafka UI (optional, only if running with --profile tools) ===
KAFKA_UI_PORT=8080
