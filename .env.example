# === App ===
NODE_ENV=development
PORT=3000

# === Postgres (docker-compose) ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=emissions
POSTGRES_USER=emissions
POSTGRES_PASSWORD=emissions

# Works for Drizzle/pg:
DATABASE_URL=postgresql://emissions:emissions@localhost:5432/emissions

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# === Kafka (KRaft single-broker) ===
KAFKA_PORT=9092
KAFKA_BROKERS=localhost:9092

# Topic names
INGEST_TOPIC=emissions.ingest.v1

# Redis edge-dedupe TTL for batch_id keys (seconds). Default: 24 h.
BATCH_DEDUPE_TTL_SECONDS=86400

# === pgAdmin (optional, only if running with --profile tools) ===
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# === Kafka UI (optional, only if running with --profile tools) ===
KAFKA_UI_PORT=8080
