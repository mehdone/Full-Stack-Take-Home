@startuml Dynamic_Ingest
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Sequence.puml

title Dynamic — Successful POST /ingest (happy path)

Person_Ext(device, "Field Device", "Retries with stable batch_id")
Container(api, "API", "NestJS")
ContainerDb(redis, "Redis")
ContainerQueue(kafka, "Kafka", "emissions.ingest.v1")
Container(consumer, "Ingest Consumer", "NestJS standalone")
ContainerDb(postgres, "PostgreSQL")
Container(outbox_relay, "Outbox Relay")
Container(metrics_relay, "Metrics Relay")
Container(alerting, "Alerting Receiver")

Rel(device, api, "1. POST /ingest { batch_id, site_slug, measurements }")
Rel(api, redis, "2. SISMEMBER sites:valid site_slug")
Rel(api, redis, "3. batchDedupe Lua (HSETNX + HEXPIRE) → first-sight = 1")
Rel(api, kafka, "4. Produce emissions.ingest.v1 keyed by site_slug")
Rel(api, device, "5. 202 { batch_id, status: queued, measurements_received }")

Rel(kafka, consumer, "6. Deliver record")
Rel(consumer, postgres, "7. Resolve site_id + timezone (cache or SELECT)")
Rel(consumer, postgres, "8. Resolve emission_point ids (cache → SELECT → INSERT ON CONFLICT)")
Rel(consumer, postgres, "9. BEGIN; INSERT measurements ON CONFLICT DO NOTHING RETURNING")
Rel(consumer, postgres, "10. UPSERT site_monthly_emissions SET stale=true (PAST site-local months only)")
Rel(consumer, postgres, "11. INSERT outbox (event_type=ingest.batch.persisted)")
Rel(consumer, postgres, "12. INSERT metrics_outbox (one row per affected site-local (year, month)); COMMIT")

Rel(outbox_relay, postgres, "13. SELECT outbox FOR UPDATE SKIP LOCKED")
Rel(outbox_relay, alerting, "14. POST /alerts/business (X-Idempotency-Key = outbox_id)")
Rel(outbox_relay, postgres, "15. UPDATE outbox SET delivered_at = now()")

Rel(metrics_relay, postgres, "16. SELECT metrics_outbox FOR UPDATE SKIP LOCKED")
Rel(metrics_relay, redis, "17. EVAL SETNX-guarded Lua: HINCRBYFLOAT metrics:<site_id> <yyyymm> <delta_kg>; HEXPIRE field")
Rel(metrics_relay, postgres, "18. UPDATE metrics_outbox SET delivered_at = now()")

SHOW_LEGEND()
@enduml
