{
  "name": "@highwood/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "drizzle-orm": "0.36.4",
    "postgres": "3.4.5"
  },
  "devDependencies": {
    "@types/node": "20.17.10",
    "drizzle-kit": "0.30.1",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  }
}
